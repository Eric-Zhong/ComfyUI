"},"widgets_values":["vae-ft-mse-840000-ema-pruned.safetensors 简介\nvae-ft-mse-840000-ema-pruned.safetensors 是一个用于 Stable Diffusion 文本转图像模型的预训练模型文件。它基于 VAE（变分自编码器）架构，并使用均方误差 (MSE) 损失函数进行训练。该模型包含 840,000 个参数，经过剪枝以提高效率。\n\n该模型的优势在于：\n\n可以生成更高质量的图像，尤其是在细节方面\n具有更快的推理速度\n占用更少的内存空间\n该模型的应用场景包括：\n\n生成创意图像\n图像编辑\n图像生成研究\n使用方法：\n\n下载 vae-ft-mse-840000-ema-pruned.safetensors 文件\n将其放置在 Stable Diffusion 的模型目录中\n在 Stable Diffusion 中加载该模型即可使用"],"color":"#432","bgcolor":"#653"},{"id":34,"type":"VAEDecode","pos":[2600,590],"size":[210,46],"flags":{},"order":17,"mode":0,"inputs":[{"name":"samples","localized_name":"samples","label":"samples","type":"LATENT","link":24},{"name":"vae","localized_name":"vae","label":"vae","type":"VAE","link":23}],"outputs":[{"name":"IMAGE","localized_name":"IMAGE","label":"IMAGE","type":"IMAGE","shape":3,"links":[26,28],"slot_index":0}],"properties":{"cnr_id":"comfy-core","ver":"0.3.24","Node name for S&R":"VAEDecode"},"widgets_values":[]},{"id":38,"type":"SaveImage","pos":[2870,430],"size":[315,270],"flags":{"collapsed":true},"order":19,"mode":0,"inputs":[{"name":"images","localized_name":"images","label":"images","type":"IMAGE","link":28}],"outputs":[],"properties":{"cnr_id":"comfy-core","ver":"0.3.24","Node name for S&R":"SaveImage"},"widgets_values":["ComfyUI"]}],"links":[[1,4,0,3,0,"MODEL"],[2,5,0,3,3,"LATENT"],[3,4,1,6,0,"CLIP"],[4,6,0,3,1,"CONDITIONING"],[5,4,1,7,0,"CLIP"],[6,7,0,3,2,"CONDITIONING"],[10,11,0,8,1,"VAE"],[16,3,0,8,0,"LATENT"],[18,3,0,32,0,"LATENT"],[19,32,0,33,3,"LATENT"],[20,4,0,33,0,"MODEL"],[21,6,0,33,1,"CONDITIONING"],[22,7,0,33,2,"CONDITIONING"],[23,11,0,34,1,"VAE"],[24,33,0,34,0,"LATENT"],[26,34,0,37,0,"IMAGE"],[27,8,0,37,1,"IMAGE"],[28,34,0,38,0,"IMAGE"]],"groups":[],"config":{},"extra":{"ds":{"scale":0.8769226950000023,"offset":[-973.7435372868375,166.89489393583145]},"workspace_info":{"id":"2ac2e9cd-428e-476b-95ba-49d3d63047e7","saveLock":false,"cloudID":null,"coverMediaPath":null},"ue_links":[]},"version":0.4}