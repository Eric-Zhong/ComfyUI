k": 9, "label": "images"}], "properties": {}, "widgets_values": ["Result"]}, {"id": 12, "type": "Note", "pos": [900, -20], "size": {"0": 270, "1": 250}, "flags": {}, "order": 2, "mode": 0, "properties": {"text": ""}, "widgets_values": ["KSampler\n========\n\nDPMPP_2M / KARRAS is generally a good overall performer and a safe bet but experiment with others!\n\nLess \"predictable\" samplers are those ending with _SDE and _ANCESTRAL.\n\nIf results are underwhelming increase the number of steps (+5 at a time).\n\nIf the image looks over-saturated lower the CFG value."], "color": "#432", "bgcolor": "#653"}, {"id": 15, "type": "Note", "pos": [1184, -19], "size": [286.8465440161715, 247.68128832296702], "flags": {}, "order": 3, "mode": 0, "properties": {"text": ""}, "widgets_values": ["KSampler\nDPMPP_2M / KARRAS \u901a\u5e38\u662f\u4e00\u4e2a\u6574\u4f53\u8868\u73b0\u826f\u597d\u4e14\u5b89\u5168\u7684\u9009\u62e9\uff0c\u4f46\u5efa\u8bae\u5c1d\u8bd5\u5176\u4ed6\u9009\u9879\uff01\n\n\u4e0d\u592a\u201c\u53ef\u9884\u6d4b\u201d\u7684\u91c7\u6837\u5668\u662f\u90a3\u4e9b\u4ee5 _SDE \u548c _ANCESTRAL \u7ed3\u5c3e\u7684\u3002\n\n\u5982\u679c\u7ed3\u679c\u4e0d\u7406\u60f3\uff0c\u53ef\u4ee5\u589e\u52a0\u6b65\u9aa4\u6570\uff08\u6bcf\u6b21\u589e\u52a05\u6b65\uff09\u3002\n\n\u5982\u679c\u56fe\u50cf\u770b\u8d77\u6765\u8fc7\u4e8e\u9971\u548c\uff0c\u53ef\u4ee5\u964d\u4f4e CFG \u503c\u3002"], "color": "#432", "bgcolor": "#653"}, {"id": 11, "type": "Note", "pos": [19, -4], "size": [338.8767788694979, 226.0071690480572], "flags": {}, "order": 4, "mode": 0, "properties": {"text": ""}, "widgets_values": ["Basic 1.x/2.x workflow\n======================\n\nUse this workflow only if you are sure the base checkpoint embeds a good quality VAE, otherwise check the \"ext_vae\" workflow.\n\n\u57fa\u672c 1.x/2.x \u5de5\u4f5c\u6d41\u7a0b\n\u4ec5\u5728\u786e\u5b9a\u57fa\u7840\u68c0\u67e5\u70b9\u5d4c\u5165\u4e86\u9ad8\u8d28\u91cf\u7684 VAE \u65f6\u4f7f\u7528\u6b64\u5de5\u4f5c\u6d41\u7a0b\uff0c\u5426\u5219\