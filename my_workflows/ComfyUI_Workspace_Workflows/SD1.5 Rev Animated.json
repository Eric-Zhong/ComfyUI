ype":"VAE","links":[],"slot_index":2}],"properties":{"cnr_id":"comfy-core","ver":"0.3.24","Node name for S&R":"CheckpointLoaderSimple"},"widgets_values":["SD15\\revAnimated_v2Rebirth.safetensors"]},{"id":28,"type":"Note","pos":[1300,580],"size":[408.729248046875,323.6429138183594],"flags":{"pinned":false},"order":3,"mode":0,"inputs":[],"outputs":[],"properties":{"text":""},"widgets_values":["vae-ft-mse-840000-ema-pruned.safetensors 简介\nvae-ft-mse-840000-ema-pruned.safetensors 是一个用于 Stable Diffusion 文本转图像模型的预训练模型文件。它基于 VAE（变分自编码器）架构，并使用均方误差 (MSE) 损失函数进行训练。该模型包含 840,000 个参数，经过剪枝以提高效率。\n\n该模型的优势在于：\n\n可以生成更高质量的图像，尤其是在细节方面\n具有更快的推理速度\n占用更少的内存空间\n该模型的应用场景包括：\n\n生成创意图像\n图像编辑\n图像生成研究\n使用方法：\n\n下载 vae-ft-mse-840000-ema-pruned.safetensors 文件\n将其放置在 Stable Diffusion 的模型目录中\n在 Stable Diffusion 中加载该模型即可使用"],"color":"#432","bgcolor":"#653"},{"id":12,"type":"Note","pos":[460,410],"size":[617.3935546875,88],"flags":{"pinned":true},"order":4,"mode":0,"inputs":[],"outputs":[],"title":"正向提示词","properties":{"text":""},"widgets_values":["((最佳质量)), ((杰作)), (详细), 魅魔, 空灵之美, 栖息在云端, (幻想插图:1.3), 迷人的目光, 紧身衣, 丝裤袜, 长袜, 连体衣, 迷人的姿态, 纤细的翅膀, 超凡的魅力, 神秘的天空, 大月亮, 月光夜, 柔和的色彩, (详细的云景:1.3), (高分辨率:1.2), 从下方, (评级_露骨), (评分_9, 评分_8以上, 评分_7以上, 评分_6以上, 评分_5以上, 评分_4以上, 高分辨率, 4k)"],"color":"#432","bgcolor":"#653"},{"id":13,"type":"Note","pos":[458,738],"size":[618.592529296875,88],"flags":{"pinned":true},"order":5,"mode":0,"inputs":[],"outputs":[],"title":"反向提示词","properties":{"text":""},"widgets_values":["（裸露，大腿，乳沟：1.3），3D，卡通，动漫，素描，（最差质量，差质量，儿童，裁剪：1.4），（（单色）），（（灰度）），（安全等级），（评分3以上，评分4以上，评分5以上，单色，矢量艺术，模糊）\n"],"color":"#432","bgcolor":"#653"},{"id":3,"type":"KSampler","pos":[1300,132],"size":[404.7532653808594,853.1298828125],"flags":{"pinned":true},"order":11,"mode":0,"inputs":[{"name":"model","localized_name":"model","label":"model","type":"MODEL","link":1},{"name":"positive","localized_name":"positive","label":"positive","type":"CONDITIONING","link":4},{"name":"negative","localized_name":"negative","label":"negative","type":"CONDITIONING","link":6},{"name":"latent_image","localized_name":"latent_image","label":"latent_image","type":"LATENT","link":2}],"outputs":[{"name":"LATENT","localized_name":"LATENT","label":"LATENT","type":"LATENT","links":[16,18],"slot_index":0}],"properties":{"cnr_id":"comfy-core","ver":"0.3.24","Node name for S&R":"KSampler"},"widgets_values":[884135741887599,"fixed",30,6,"dpmpp_2m","karras",0.8]},{"id":30,"type":"Note","pos":[1773,-180],"size":[442.7279968261719,258.08721923828125],"flags":{},"order":6,"mode":0,"inputs":[],"outputs":[],"properties":{"text":""},"widgets_values":["KSampler 的参数\nKSampler 具有多个参数可供用户调整，这些参数会影响图像生成结果。一些重要的参数包括：\n\nsteps 步长: 控制图像更新的幅度\n迭代次数: 控制生成过程的总步数\n温度: 控制图像的创造性和多样性\ncfg 引导强度: 控制文本提示对图像生成的影响程度\n\nKSampler 的应用\nKSampler 可用于各种图像生成任务，包括：\n\n文本转图像: 从文本描述生成图像\n图像编辑: 调整现有图像\n创意图像生成: 生成新颖和独特的图像"],"color":"#432","bgcolor":"#653"},{"id":29,"type":"Note","pos":[1306,-179],"size":[442.7279968261719,258.08721923828125],"flags":{},"order":7,"mode":0,"inputs":[],"outputs":[],"properties":{"text":""},"widgets_values":["KSampler 简介\n在 Stable Diffusion 中，KSampler 是一个用于生成图像的关键节点。它通过将随机噪声转换为与文本提示相匹配的图像来实现图像生成。KSampler 是 ComfyUI 中一个重要的组成部分，可让用户控制和定制图像生成过程。\n\nKSampler 的工作原理\nKSampler 采用迭代过程来生成图像。在每个迭代步骤中，它会根据以下因素更新图像：\n\n文本提示: 通过 CLIP 模型编码的文本描述\n模型输出: 来自 Unet 模型的潜在空间表示\n随机噪声: 用于确保图像多样性的随机元素\nKSampler 使用各种技术来提高图像质量和生成效率，包括：\n\n引导扩散: 逐步将随机噪声转换为与提示相匹配的图像\n降噪: 逐步去除噪声以锐化图像\n超分辨率: 提高图像分辨率"],"color":"#432","bgcolor":"#653"},{"id":10,"type":"Note","pos":[-121,-381],"size":[2539.0478515625,143.15992736816406],"flags":{"pinned":false},"order":8,"mode":0,"inputs":[],"outputs":[],"properties":{"text":""},"widgets_values":["Target: Use ReV Animated model generate some images for learning."],"color":"#432","bgcolor":"#653"},{"id":6,"type":"CLIPTextEncode","pos":[460,240],"size":[622.5296020507812,121.95561981201172],"flags":{"collapsed":false,"pinned":false},"order":9,"mode":0,"inputs":[{"name":"clip","localized_name":"clip","label":"clip","type":"C